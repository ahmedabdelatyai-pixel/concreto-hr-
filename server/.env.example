# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/talentflow-hr?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# CORS Configuration (comma-separated list)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Gemini AI API (for CV analysis and interview questions)
GEMINI_API_KEY=your-gemini-api-key-here

# Email Configuration (optional for future notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Vercel Environment
VERCEL_ENV=development
